---
// src/components/ai/TokenChart.astro
import type { DailyUsage } from '../../types/ai-usage'

interface Props {
  data: DailyUsage[]
  title?: string
}

const { data, title = '月度趋势' } = Astro.props

// Group by month
const monthlyData = new Map<string, number>()
for (const day of data) {
  const month = day.date.substring(0, 7)
  monthlyData.set(month, (monthlyData.get(month) || 0) + day.totalTokens)
}

const sortedMonths = Array.from(monthlyData.entries()).sort((a, b) => a[0].localeCompare(b[0]))
const maxTokens = Math.max(...sortedMonths.map(d => d[1]), 1)

// SVG dimensions
const width = 800
const height = 200
const padding = { top: 20, right: 30, bottom: 40, left: 60 }
const chartWidth = width - padding.left - padding.right
const chartHeight = height - padding.top - padding.bottom

// Generate bar positions
const barWidth = sortedMonths.length > 0 ? chartWidth / sortedMonths.length * 0.6 : 0
const barSpacing = sortedMonths.length > 0 ? chartWidth / sortedMonths.length : 0

function formatMonth(monthStr: string): string {
  const [year, month] = monthStr.split('-')
  return `${year}年${month}月`
}

function formatTokens(tokens: number): string {
  if (tokens >= 1_000_000) return (tokens / 1_000_000).toFixed(1) + 'M'
  if (tokens >= 1_000) return (tokens / 1_000).toFixed(1) + 'K'
  return tokens.toString()
}
---

<div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700 mb-6">
  <h3 class="text-lg font-semibold mb-4 text-gray-800 dark:text-gray-200">{title}</h3>

  {sortedMonths.length === 0 ? (
    <div class="text-gray-500 text-center py-8">暂无数据</div>
  ) : (
    <div class="overflow-x-auto">
      <svg viewBox={`0 0 ${width} ${height}`} class="w-full min-w-[600px]" preserveAspectRatio="xMidYMid meet">
        {/* Grid lines */}
        {[0, 0.25, 0.5, 0.75, 1].map((ratio, i) => {
          const y = padding.top + chartHeight * (1 - ratio)
          return (
            <g>
              <line
                x1={padding.left}
                y1={y}
                x2={width - padding.right}
                y2={y}
                stroke="#e5e7eb"
                stroke-dasharray="4,4"
                class="dark:stroke-gray-700"
              />
              <text
                x={padding.left - 10}
                y={y + 4}
                text-anchor="end"
                class="text-xs fill-gray-500 dark:fill-gray-400"
              >
                {formatTokens(Math.round(maxTokens * ratio))}
              </text>
            </g>
          )
        })}

        {/* Bars */}
        {sortedMonths.map(([month, tokens], index) => {
          const barHeight = (tokens / maxTokens) * chartHeight
          const x = padding.left + index * barSpacing + (barSpacing - barWidth) / 2
          const y = padding.top + chartHeight - barHeight

          return (
            <g>
              <rect
                x={x}
                y={y}
                width={barWidth}
                height={barHeight}
                fill="#3b82f6"
                rx="4"
                class="hover:fill-blue-500 transition-colors"
              />
              <text
                x={x + barWidth / 2}
                y={height - 10}
                text-anchor="middle"
                class="text-xs fill-gray-600 dark:fill-gray-400"
                transform={`rotate(-45, ${x + barWidth / 2}, ${height - 10})`}
              >
                {formatMonth(month)}
              </text>
            </g>
          )
        })}
      </svg>
    </div>
  )}
</div>
