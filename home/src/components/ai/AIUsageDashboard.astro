---
// src/components/ai/AIUsageDashboard.astro
import { loadAIUsageData } from '../../utils/ai-usage-loader'
import DeviceSelector from './DeviceSelector.astro'
import MonthlyStats from './MonthlyStats.astro'
import TokenChart from './TokenChart.astro'
import ModelDistribution from './ModelDistribution.astro'
import UsageHeatmap from './UsageHeatmap.astro'

// Get query parameter
const url = new URL(Astro.request.url)
const selectedDevice = url.searchParams.get('device') || 'all'

// Load data
const data = await loadAIUsageData()

// Filter data by device
const devices = data.summary.deviceList
const isValidDevice = selectedDevice === 'all' || devices.includes(selectedDevice)
const currentDevice = isValidDevice ? selectedDevice : 'all'

// Get data for current view
const currentData = currentDevice === 'all'
  ? Object.values(data.total.byMonth).flat()
  : Object.values(data.byDevice[currentDevice]?.byMonth || {}).flat()

// Calculate monthly tokens for current month
const currentMonth = new Date().toISOString().substring(0, 7)
const monthlyData = currentDevice === 'all'
  ? data.total.byMonth[currentMonth] || []
  : data.byDevice[currentDevice]?.byMonth[currentMonth] || []
const monthlyTokens = monthlyData.reduce((sum, d) => sum + d.totalTokens, 0)

// Calculate summary for current view
const totalTokens = currentData.reduce((sum, d) => sum + d.totalTokens, 0)

// Calculate model distribution for current view
const byModel: Record<string, number> = {}
for (const day of currentData) {
  for (const breakdown of day.modelBreakdowns) {
    const tokens = breakdown.inputTokens + breakdown.outputTokens + breakdown.cacheReadTokens
    byModel[breakdown.modelName] = (byModel[breakdown.modelName] || 0) + tokens
  }
}
---

<div class="max-w-4xl mx-auto">
  <div class="flex items-center gap-2 mb-6">
    <span class="text-2xl">🤖</span>
    <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-100">AI Usage Statistics</h2>
  </div>

  <DeviceSelector devices={devices} selected={currentDevice} />

  {currentData.length === 0 ? (
    <div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-12 text-center border border-gray-200 dark:border-gray-700">
      <div class="text-4xl mb-4">📊</div>
      <h3 class="text-lg font-medium text-gray-800 dark:text-gray-200 mb-2">暂无数据</h3>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        请将 ccusage 生成的 JSON 文件放入 <code class="bg-gray-100 dark:bg-gray-700 px-2 py-1 rounded">ai/usages/</code> 目录
      </p>
      <pre class="bg-gray-100 dark:bg-gray-800 p-4 rounded-lg text-sm text-left overflow-x-auto">
ccusage -j > ai/usages/mydevice-$(date +%Y-%m).json</pre>
    </div>
  ) : (
    <>
      <MonthlyStats
        totalTokens={totalTokens}
        monthlyTokens={monthlyTokens}
      />

      <TokenChart data={currentData} />

      <div class="mb-6">
        <ModelDistribution byModel={byModel} />
      </div>

      <UsageHeatmap data={currentData} />
    </>
  )}
</div>
